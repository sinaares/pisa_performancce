# Python
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Data (usually large / private)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Outputs & models
outputs/*
models/*
!outputs/.gitkeep
!models/.gitkeep

# Environment variables — NEVER commit these
.env
.env.local
.env.production
backend/.env
frontend/.env.local
frontend/.env.production

# Node
node_modules/
.next/
frontend/node_modules/
frontend/.next/
